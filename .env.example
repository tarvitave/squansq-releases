# Copy this file to .env and fill in your values

# Required: path to the directory containing your projects
# WorkerBees will be able to read and edit code inside this directory
PROJECTS_PATH=/home/yourname/projects

# Required: random secret for signing JWT tokens
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string

# Optional: port to expose the UI on (default: 80)
PORT=80
